# Примусовий редірект на HTTPS (додано за рекомендацією підтримки хостингу —
# SSL-сертифікат встановлено, але без цього правила http:// лишався доступним).
# Не діє на localhost — там SSL не налаштований для локальної розробки.
RewriteEngine On
RewriteCond %{HTTP_HOST} !^localhost$
RewriteCond %{HTTPS} !on
RewriteRule (.*) https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

Options -Indexes

<IfModule php_module>
  php_flag expose_php off
</IfModule>

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always unset X-Powered-By
  Header unset Server
</IfModule>

RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [L]
